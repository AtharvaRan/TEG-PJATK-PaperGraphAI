# ── Project specific ──────────────────────────────────────────────────────────
.env                        # API keys — never commit
docs/                       # your PDFs — user brings their own
db/                         # ChromaDB + knowledge graph — generated locally
*.html                      # pyvis graph output
lib/                        # pyvis auto-generated JS/CSS

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ── Virtual environment ───────────────────────────────────────────────────────
venv/
.venv/
env/

# ── Mac ───────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.cursor*

# ── Misc ──────────────────────────────────────────────────────────────────────
*.log
.ruff_cache/
